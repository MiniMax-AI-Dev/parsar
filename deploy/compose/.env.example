# Parsar self-hosted deployment - env template.
#
# This file is committed as `.env.example`. The repo-root .gitignore
# refuses to commit any `.env` / `.env.<anything>` *except*
# `.env.example`, so:
#
#   1. Copy this file: cp .env.example .env
#   2. Replace every <placeholder> with the real value from your
#      secret manager (1Password / Vault / cloud KMS / K8s secret —
#      pick what your org already uses).
#   3. NEVER commit the resulting .env back into git.
#
# Compose loads this file by default when you run:
#   docker compose -f deploy/compose/compose.selfhost.yml --env-file .env up -d
#
# All values below are placeholders. Keep this file safe to share —
# it intentionally contains NO production hostnames, NO real
# registry paths, NO real app ids, NO real secrets.

# -----------------------------------------------------------------------------
# Image
# -----------------------------------------------------------------------------
# Image tag for parsar-server. Defaults (when unset) to the GHCR prebuilt
# image baked by .github/workflows/parsar-server-release.yml. For production,
# pin a real tag (commit sha / semver) instead of `latest`; mirror to your
# own registry (e.g. Aliyun ACR) and point this there for in-region pulls.
PARSAR_SERVER_IMAGE=ghcr.io/minimax-ai-dev/parsar-server:latest

# -----------------------------------------------------------------------------
# Host port mapping
# -----------------------------------------------------------------------------
# Compose binds these to 127.0.0.1 only — a reverse proxy (nginx /
# caddy / ingress) is expected to terminate TLS and forward upstream.
PARSAR_HOST_PORT=8080
PARSAR_PG_HOST_PORT=5432

# -----------------------------------------------------------------------------
# Postgres (only used if you keep the bundled postgres service)
# -----------------------------------------------------------------------------
# If you point at an external Postgres, comment out the postgres
# service in compose.selfhost.yml and override DATABASE_URL instead
# (the variable does not have to live in this file — env-file is just
# one of several injection paths).
PARSAR_PG_USER=parsar
PARSAR_PG_PASSWORD=<placeholder generate with: openssl rand -hex 24>
PARSAR_PG_DB=parsar

# -----------------------------------------------------------------------------
# Public-facing URL
# -----------------------------------------------------------------------------
# Absolute URL the browser hits. Used to construct OAuth callback URLs
# for optional providers such as Feishu and GitHub. MUST start with
# https:// in production and MUST match what your reverse proxy serves on.
PARSAR_PUBLIC_URL=https://parsar.<placeholder-your-domain>

# -----------------------------------------------------------------------------
# Secret master key (AES-GCM wrap key for the workspace secret vault)
# -----------------------------------------------------------------------------
# Generate once, keep in your secret manager FOREVER. Rotating this
# key requires re-encrypting every workspace secret — there is no
# in-place rotation today.
#
#   openssl rand -hex 32
PARSAR_MASTER_KEY=<placeholder 64-hex-chars>

# -----------------------------------------------------------------------------
# Optional Feishu SSO + event subscription
# -----------------------------------------------------------------------------
# Leave these empty for the default first-owner setup and email/password
# login. Fill in the values only when enabling Feishu SSO or Feishu IM
# event delivery.
#
# Where to get the production values:
#   docs/deploy/feishu-prod.md §1 (Feishu open platform setup)
PARSAR_FEISHU_MOCK=
PARSAR_FEISHU_APP_ID=
PARSAR_FEISHU_APP_SECRET=
PARSAR_FEISHU_REDIRECT_URI=
PARSAR_FEISHU_VERIFICATION_TOKEN=
# Only set when Feishu event encryption is on:
PARSAR_FEISHU_ENCRYPT_KEY=
# Login redirect post-callback (defaults to "/"):
PARSAR_LOGIN_REDIRECT_URL=

# Override only when you reverse-proxy Feishu through a private
# endpoint (rare). Leave blank to use the public Feishu hosts.
PARSAR_FEISHU_AUTHORIZE_BASE=
PARSAR_FEISHU_API_BASE=

# -----------------------------------------------------------------------------
# GitHub personal account connection (OAuth App)
# -----------------------------------------------------------------------------
# Creates/rotates the signed-in user's github_pat credential after OAuth.
# Register this callback in GitHub when overriding the auto-built URI:
#   https://<your-parsar-host>/api/v1/connections/github/callback
PARSAR_GITHUB_CLIENT_ID=
PARSAR_GITHUB_CLIENT_SECRET=
PARSAR_GITHUB_REDIRECT_URI=
PARSAR_GITHUB_SCOPE=repo read:user user:email

# -----------------------------------------------------------------------------
# Sandbox runner (Agent Daemon)
# -----------------------------------------------------------------------------
# Where the in-image install-parsar-daemon.sh fetches its binary from.
# Empty = the script's built-in default (`MiniMax-AI-Dev/parsar` GitHub
# Releases). Override to your fork's `owner/name` slug if you publish
# your own parsar-daemon release stream.
PARSAR_DAEMON_REPO=

# AGENT_DAEMON_OWNER_URL is how in-sandbox parsar-daemon reaches back to
# the server. compose.selfhost.yml defaults this to the compose-internal
# service name so a fresh `docker compose up` works without any extra
# wiring. Override only when running parsar-daemon across a different
# network (e.g. external host, K8s with downward-API POD_IP).
PARSAR_AGENT_DAEMON_OWNER_URL=

# OpenCode runs are dispatched through the Agent Daemon connector
# (`connector_type=agent_daemon` + `project_agents.config.agent_kind=opencode`)
# to either a paired `parsar-daemon` device or a platform-managed sandbox.
# The values below only matter for the sandbox path — leave blank to
# stay on local-daemon runtimes.
PARSAR_E2B_API_KEY=
# Custom template id (defaults to the public parsar-opencode-base
# template when blank — fork it into your account if you need custom
# pre-installs).
PARSAR_E2B_TEMPLATE_ID=
# Per-sandbox max wall-clock (seconds). Default 3600 in code.
PARSAR_E2B_TIMEOUT_SECONDS=
# Override only when E2B's API base URL is reverse-proxied.
PARSAR_E2B_API_BASE_URL=

# -----------------------------------------------------------------------------
# Object storage (Aliyun OSS) — required for Plugin capability uploads
# -----------------------------------------------------------------------------
# Backs the plugin-zip upload + dispatch flow exposed under
# /api/v1/dev/uploads and /api/v1/dev/capabilities/* (Skill / MCP /
# Plugin import dialog → "Plugin" tab). The server constructs the
# client once at boot; ANY blank required field disables Plugin uploads
# (UI surfaces "object storage is not configured on this deployment").
# MCP + Skill capability flows are unaffected.
#
# Region format: the SDK expects the bare region code (cn-shanghai,
# cn-hangzhou, …), NOT the `oss-` prefixed endpoint host. The
# `oss-cn-shanghai.aliyuncs.com` form only appears inside BASE_URL.
#
# Same bucket is safe to share across parsar + sibling services —
# parsar namespaces every object under
# `capabilities/(plugins|skills)/<workspace_id>/...`, so a sibling
# service writing under a different prefix (e.g. workspace files)
# cannot collide and the cross-tenant guard
# (oss.KeyBelongsToWorkspace) prevents one workspace's admin from
# downloading another's zip.
PARSAR_OSS_REGION=
PARSAR_OSS_BUCKET=
PARSAR_OSS_ACCESS_KEY_ID=
PARSAR_OSS_ACCESS_KEY_SECRET=
# BASE_URL is the bucket's public origin — concat with the object key
# to produce the URL stored in capability_versions.oss_url. Required
# because the SDK does not derive it for VPC / dual-stack endpoints.
PARSAR_OSS_BASE_URL=
# Override only when reverse-proxying or using a VPC endpoint.
# Leave blank to let the SDK derive from region.
PARSAR_OSS_ENDPOINT=

# -----------------------------------------------------------------------------
# Audit / OTLP fan-out (optional)
# -----------------------------------------------------------------------------
# Leave disabled unless your org already runs an OpenTelemetry
# collector and wants Parsar audit events copied into Grafana /
# Tempo / Loki / Honeycomb / Datadog. The canonical audit_records
# table is always written regardless.
#
# Production MUST set PARSAR_AUDIT_OTLP_SIGNING_KEY when
# PARSAR_AUDIT_OTLP_ENABLED=true — receiver refuses to start with
# a blank key.
#
#   openssl rand -hex 32
PARSAR_AUDIT_OTLP_ENABLED=false
PARSAR_AUDIT_OTLP_ADDR=:4318
PARSAR_AUDIT_OTLP_SIGNING_KEY=
PARSAR_AUDIT_OTLP_EXTERNAL_ENDPOINT=
PARSAR_AUDIT_OTLP_FANOUT_ENDPOINT=

# -----------------------------------------------------------------------------
# Bind-mount paths (host-side)
# -----------------------------------------------------------------------------
# Where the *host* keeps the rendered config file and the runtime
# state directory. Both MUST be absolute paths OUTSIDE the Parsar repo
# checkout (e.g. /etc/parsar/ and /var/lib/parsar/, owned by the
# deploy user). The compose file uses `${VAR:?msg}` so an empty value
# fails fast instead of silently bind-mounting into the repo CWD.
PARSAR_CONFIG_HOST_PATH=/etc/parsar/config.yaml
PARSAR_DATA_HOST_PATH=/var/lib/parsar
